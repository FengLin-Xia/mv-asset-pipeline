# MV 案例资产拆解 Pipeline 环境变量配置
# 使用方法：cp .env.example .env，然后填入实际值

# ── Step 5 视觉 Caption（必须配置，否则用 --skip-caption 跳过）──

# API Key（必填）
VLM_API_KEY=your_api_key_here

# API 地址（可选，默认 OpenAI；兼容任何 OpenAI 格式的接口，如 Azure、本地部署等）
VLM_API_BASE=https://api.openai.com/v1

# 使用的模型（可选，默认 gpt-4o；需支持图像输入）
VLM_MODEL=gpt-4o
